# =============================================
# CONFIGURACIÓN DEL SERVIDOR
# =============================================
PORT=3000

# =============================================
# BASE DE DATOS MONGODB
# Reemplaza con tu connection string de MongoDB Atlas
# Formato: mongodb+srv://usuario:contraseña@cluster.mongodb.net/nombre_bd
# =============================================
MONGODB_URI=mongodb://localhost:27017/auth_system

# =============================================
# JWT SECRET - Cambia esto por una cadena aleatoria larga y segura
# Puedes generar una en: https://generate-secret.vercel.app/64
# =============================================
JWT_SECRET=cambia_esto_por_una_clave_super_secreta_aleatoria_123

# =============================================
# CREDENCIALES DEL ADMINISTRADOR PRINCIPAL
# Este admin se crea automáticamente al iniciar el servidor
# =============================================
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=TuContraseñaSegura2024!

# =============================================
# DURACIÓN DEL TOKEN JWT
# Ejemplos: 1h, 2h, 8h, 24h, 7d
# =============================================
JWT_EXPIRES_IN=8h

# =============================================
# CONFIGURACIÓN DE SEGURIDAD
# =============================================
# Máximo de intentos de login antes de bloquear (por IP)
MAX_LOGIN_ATTEMPTS=10
# Ventana de tiempo en minutos para el rate limit
RATE_LIMIT_WINDOW=15
